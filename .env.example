# Copy to .env.local and adjust values
VITE_PB_URL=http://127.0.0.1:8090
VITE_PB_PUBLIC_URL=http://127.0.0.1:8090
VITE_APP_URL=http://localhost:8080
VITE_PB_ADMIN_EMAIL=admin@aitherwarth.local
VITE_PB_ADMIN_PASSWORD=your-superuser-password

# Email (required for forgot-password & verification emails)
# Gmail example: use an App Password, port 587, tls false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=your@gmail.com
